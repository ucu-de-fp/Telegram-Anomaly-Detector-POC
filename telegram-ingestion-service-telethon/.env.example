# .env.example
# Copy to .env and fill in the values for local development.
# Never commit the real .env to version control.

# ── Profiles ──────────────────────────────────────────────────────────────────
# Set to "test" to use the local file source instead of live Telegram.
# Can be a comma-separated list: "dev,test"
PROFILES=test

# ── Telegram (only needed when PROFILES does NOT contain "test") ──────────────
# Obtain at https://my.telegram.org/apps
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_SESSION_NAME=session/telegram_session

# ── Test source file ──────────────────────────────────────────────────────────
# Path to a Telegram Desktop "Export chat history" JSON file.
# Export via: Settings → Export Telegram Data → Machine-readable JSON
TEST_MESSAGES_FILE=test_data/result.json

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=admin
DB_USER=monitoring
DB_PASSWORD=monitoring123

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=monitoring
RABBITMQ_PASSWORD=monitoring123
RABBITMQ_EXCHANGE=telegram.messages
RABBITMQ_ROUTING_KEY=telegram.message.ingested

# ── HTTP API ──────────────────────────────────────────────────────────────────
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
