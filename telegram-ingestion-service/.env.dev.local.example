# .env.example
# Copy to .env and fill in the values for local development.
# Never commit the real .env to version control.

# ── Message source ────────────────────────────────────────────────────────────
# Possible values:
# TELEGRAM - to read messages from telegram
# FILE - to read messages from TEST_MESSAGES_FILE
# RANDOM_MESSAGES - to generate messages based on the config in RANDOM_SOURCE_CONFIG
MESSAGE_SOURCE=RANDOM_MESSAGES

# ── Telegram (only needed when PROFILES does NOT contain "test") ──────────────
# Obtain at https://my.telegram.org/apps
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_SESSION_NAME=telegram_session

# ── Test source file ──────────────────────────────────────────────────────────
# Path to a Telegram Desktop "Export chat history" JSON file.
# Export via: Settings → Export Telegram Data → Machine-readable JSON
TEST_MESSAGES_FILE=test/resources/group1.json

# TODO: make relative path
RANDOM_SOURCE_CONFIG=<PATH_TO_PROJECT_ROOT>/telegram-ingestion-service/test/resources/random_messages.toml

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=admin
DB_USER=monitoring
DB_PASSWORD=monitoring123

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=monitoring
RABBITMQ_PASSWORD=monitoring123
RABBITMQ_EXCHANGE=telegram.messages
# RABBITMQ_ROUTING_KEY=telegram.message.ingested
RABBITMQ_ROUTING_KEY=telegram-events

# ── HTTP API ──────────────────────────────────────────────────────────────────
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
